# ============================================
# 小红书 MCP 配置文件模板
# ============================================
# 使用说明:
# 1. 复制此文件为 config.yaml
# 2. 根据实际情况修改配置项
# 3. 启动服务时会自动加载配置文件
# ============================================

# 服务器配置
server:
  # 服务监听端口
  port: ":18060"
  
  # 监听地址 (默认所有接口)
  host: "0.0.0.0"

# 浏览器配置
browser:
  # 是否无头模式 (生产环境建议 true)
  headless: true
  
  # 浏览器二进制文件路径 (可选，默认自动检测)
  # bin_path: "/usr/bin/google-chrome"
  
  # 浏览器用户数据目录
  # user_data_dir: "/var/lib/xiaohongshu-mcp/browser-data"
  
  # 浏览器启动参数
  # args:
  #   - "--no-sandbox"
  #   - "--disable-dev-shm-usage"

# 代理配置 (可选)
# proxy:
#   # 代理地址
#   url: "http://proxy.example.com:8080"
#   # 代理用户名 (如果需要认证)
#   username: ""
#   # 代理密码 (如果需要认证)
#   password: ""

# 日志配置
logging:
  # 日志级别 (debug, info, warn, error)
  level: "info"
  
  # 日志输出格式 (json, text)
  format: "text"
  
  # 日志文件路径 (可选，默认输出到 systemd journal)
  # file: "/var/log/xiaohongshu-mcp/app.log"

# 数据存储配置
storage:
  # Cookies 存储路径
  cookies_path: "/var/lib/xiaohongshu-mcp/cookies.json"
  
  # 图片存储路径
  images_path: "/var/lib/xiaohongshu-mcp/images"
  
  # 临时文件存储路径
  temp_path: "/tmp/xiaohongshu-mcp"

# 安全配置
security:
  # API 访问令牌 (可选，用于保护 API 端点)
  # api_token: "your-secret-token-here"
  
  # 允许的 CORS 来源 (可选)
  # allowed_origins:
  #   - "http://localhost:3000"
  #   - "https://your-domain.com"

# 性能配置
performance:
  # 最大并发请求数
  max_concurrent_requests: 5
  
  # 请求超时时间 (秒)
  timeout: 60
  
  # 重试次数
  retry_count: 3
  
  # 重试间隔 (秒)
  retry_interval: 2
